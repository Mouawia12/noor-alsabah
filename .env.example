APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===== قاعدة البيانات: Oracle (الإنتاج) =====
# لا تضع بيانات اعتماد حقيقية في المستودع — تُضبط على الخادم فقط داخل .env
DB_CONNECTION=oracle
DB_HOST=
DB_PORT=1521
DB_DATABASE=
DB_SERVICE_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=AL32UTF8
DB_TNS=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ===== الذكاء الاصطناعي (المشتريات/الإيجارات) =====
AI_ENGINE=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o
AI_CONFIDENCE_THRESHOLD=0.80
AI_MAX_PAGES_PER_BATCH=200
AI_DISK=ai_private
AI_PDF_RENDER_DPI=200
# خيارات OpenAI الإضافية (لها قيم افتراضية في config/ai.php)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=3

# ===== التشخيص: يجب أن يبقى معطّلاً في الإنتاج =====
DEBUGBAR_ENABLED=false
